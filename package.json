{
  "name": "@emagister/js-components",
  "version": "1.3.0",
  "description": "Javascript components library for Emagister projects",
  "type": "module",
  "main": "./dist/js-components.umd.cjs",
  "module": "./dist/js-components.js",
  "exports": {
    ".": {
      "import": "./dist/js-components.js",
      "require": "./dist/js-components.umd.cjs"
    },
    "./style.css": "./dist/js-components.css",
    "./scss/*": "./scss/*"
  },
  "files": [
    "dist",
    "src",
    "scss"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "javascript",
    "components",
    "emagister"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Emagister/js-components"
  },
  "author": "Emagister",
  "license": "ISC",
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.11.0",
    "flatpickr": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@vitest/coverage-v8": "^4.1.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "eslint": "^9.0.0",
    "flatpickr": "^4.6.13",
    "happy-dom": "^20.8.9",
    "sass": "^1.98.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "string-template": "^1.0.0"
  }
}
